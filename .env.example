# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_TIMEZONE=Europe/Helsinki
APP_ENCRYPTION_KEY=replace-with-32-byte-secret

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
ALLOWED_TELEGRAM_USER_IDS=

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_PLANNER_MODEL=gpt-4o-mini
OPENAI_MEMORY_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REQUIRED_FOR_NATURAL_LANGUAGE=true
ENABLE_AGENT_PLANNER_V2=true
ENABLE_MEMORY_EMBEDDINGS=false
SMART_COMMIT_MODE=auto_low_risk
DEFAULT_MORNING_REMINDER_TIME=09:30

# Reminder trigger
CRON_SECRET=

# Google Calendar OAuth (optional until user connects calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-secret

# Calendar provider
CALENDAR_PROVIDER=none

# Yandex Calendar via CalDAV (optional alternative to Google Calendar)
YANDEX_CALDAV_URL=https://caldav.yandex.ru
YANDEX_CALDAV_USERNAME=
YANDEX_CALDAV_APP_PASSWORD=
YANDEX_CALDAV_CALENDAR_URL=
YANDEX_CALENDAR_URL=
